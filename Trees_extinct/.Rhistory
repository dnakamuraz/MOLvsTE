cor.test(df_extinct$X.Morph.Total, df_extinct$MP_MOLvsTE_NormalizedMeanSPR, method = "spearman")
plot_mp_spr_mean_fossil = ggplot(df_extinct, aes(x = X.Morph.Total, y = MP_MOLvsTE_NormalizedMeanSPR)) +
geom_point() +  # scatter plot
geom_smooth(method = "lm", formula = y ~ x, color = "#335100", se = FALSE) +  # regression line (lm) for the trend
#stat_cor(method = "spearman", label.x = 0.08, label.y = 0.33) +  # add Spearman correlation value
theme_minimal()+
labs(y = "Normalized SPR\n", x = NULL)
