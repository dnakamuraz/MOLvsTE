df <- read.csv("Dataset_R_q123_08-25.csv")
# Append the extant datasets that do not appear among extinct
df_extinct <- df[df$Type == "Extinct" |
(df$Type == "Extant" & !(df$Dataset %in% extinct_datasets)), ]
print("1a. MPmol vs MPte")
print("Minimum RF")
shapiro.test(as.numeric(df_extinct$MP_MOLvsTE_NormalizedMinRF)) # non-parametric, p < 0.05
q1a_rf <- wilcox.test(as.numeric(df_extinct$MP_MOLvsTE_NormalizedMinRF), mu = 0, exact=F, conf.int=T)
q1a_rf
print("Minimum CID")
shapiro.test(as.numeric(df_extinct$MP_MOLvsTE_NormalizedMinCID))  # non-parametric, p < 0.05
q1a_cid <- wilcox.test(as.numeric(df_extinct$MP_MOLvsTE_NormalizedMinCID), mu = 0, exact=F, conf.int=T)
q1a_cid
print("Minimum SPR")
shapiro.test(as.numeric(df_extinct$MP_MOLvsTE_NormalizedMinSPR)) # non-parametric, p < 0.05
q1a_spr <- wilcox.test(as.numeric(df_extinct$MP_MOLvsTE_NormalizedMinSPR), mu = 0, exact=F, conf.int=T)
q1a_spr
print("Mean RF")
shapiro.test(as.numeric(df_extinct$MP_MOLvsTE_NormalizedMeanRF)) # non-parametric, p < 0.05
q1a_rf <- wilcox.test(as.numeric(df_extinct$MP_MOLvsTE_NormalizedMeanRF), mu = 0, exact=F, conf.int=T)
q1a_rf
print("Mean CID")
shapiro.test(as.numeric(df_extinct$MP_MOLvsTE_NormalizedMeanCID))  # non-parametric, p < 0.05
q1a_cid <- wilcox.test(as.numeric(df_extinct$MP_MOLvsTE_NormalizedMeanCID), mu = 0, exact=F, conf.int=T)
q1a_cid
print("Mean SPR")
shapiro.test(as.numeric(df_extinct$MP_MOLvsTE_NormalizedMeanSPR)) # non-parametric, p < 0.05
q1a_spr <- wilcox.test(as.numeric(df_extinct$MP_MOLvsTE_NormalizedMeanSPR), mu = 0, exact=F, conf.int=T)
q1a_spr
print("1b. MLmol vs MLteAsc")
print("RF")
print("RF")
shapiro.test(as.numeric(df_extinct$ML_MOLvsTEASC_NormalizedRF)) # non-parametric, p < 0.05
q1b_rf <- wilcox.test(as.numeric(df_extinct$ML_MOLvsTEASC_NormalizedRF), mu = 0, exact=F, conf.int=T)
q1b_rf
print("CID")
shapiro.test(as.numeric(df_extinct$ML_MOLvsTEASC_NormalizedCID)) # non-parametric, p < 0.05
q1b_cid <- wilcox.test(as.numeric(df_extinct$ML_MOLvsTEASC_NormalizedCID), mu = 0, exact=F, conf.int=T)
q1b_cid
print("SPR")
shapiro.test(as.numeric(df_extinct$ML_MOLvsTEASC_NormalizedSPR)) # parametric, p > 0.05
q1b_spr <- t.test(as.numeric(df_extinct$ML_MOLvsTEASC_NormalizedSPR), mu = 0)
q1b_spr
print("RF")
shapiro.test(as.numeric(df_extinct$ML_MOLvsTEnoASC_NormalizedRF)) # non-parametric, p < 0.05
q1c_rf <- wilcox.test(as.numeric(df_extinct$ML_MOLvsTEnoASC_NormalizedRF), mu = 0, exact=F, conf.int=T)
q1c_rf
print("CID")
shapiro.test(as.numeric(df_extinct$ML_MOLvsTEnoASC_NormalizedCID)) # non-parametric, p < 0.05
q1c_cid <- wilcox.test(as.numeric(df_extinct$ML_MOLvsTEnoASC_NormalizedCID), mu = 0, exact=F, conf.int=T)
q1c_cid
print("SPR")
shapiro.test(as.numeric(df_extinct$ML_MOLvsTEnoASC_NormalizedSPR)) # non-parametric, p < 0.05
q1c_spr <- t.test(as.numeric(df_extinct$ML_MOLvsTEnoASC_NormalizedSPR), mu = 0)
q1c_spr
# Load data
df <- read.csv("Dataset_R_q123_08-25.csv")
#df_extinct <- df %>% filter(grepl("Extinct", Type)) # keep only extinct datasets
# Keep only extinct
extinct_datasets <- unique(df$Dataset[df$Type == "Extinct"])
# Append the extant datasets that do not appear among extinct
df_extinct <- df[df$Type == "Extinct" |
(df$Type == "Extant" & !(df$Dataset %in% extinct_datasets)), ]
# Create a dataframe
df_extinct <- data.frame(
RFdist = c(df_extinct$MP_MOLvsTE_NormalizedMinRF, df_extinct$MP_MOLvsTE_NormalizedMeanRF, df_extinct$ML_MOLvsTEASC_NormalizedRF, df_extinct$ML_MOLvsTEnoASC_NormalizedRF),  # Combine the vectors into a single column
CID = c(df_extinct$MP_MOLvsTE_NormalizedMinCID, df_extinct$MP_MOLvsTE_NormalizedMeanCID, df_extinct$ML_MOLvsTEASC_NormalizedCID, df_extinct$ML_MOLvsTEnoASC_NormalizedCID),
SPR = c(df_extinct$MP_MOLvsTE_NormalizedMinSPR,df_extinct$MP_MOLvsTE_NormalizedMeanSPR, df_extinct$ML_MOLvsTEASC_NormalizedSPR, df_extinct$ML_MOLvsTEnoASC_NormalizedSPR),
comparison = base::rep(c("MPmol_MPte_min", "MPmol_MPte_mean", "MLmol_MLteAsc", "MLmol_MLteNoAsc"), each = length(df_extinct$MP_MOLvsTE_NormalizedMinRF))  # Repeat vector names
)
df_extinct$comparison <- factor(df_extinct$comparison, levels = c("MPmol_MPte_min", "MPmol_MPte_mean", "MLmol_MLteAsc", "MLmol_MLteNoAsc"))
custom_palette <- c("MPmol_MPte_min" = "#339999",
"MPmol_MPte_mean" = "#335100",
"MLmol_MLteAsc" = "#6f77b4",
"MLmol_MLteNoAsc" = "#cccccc")
custom_labels <- c(
"MPmol_MPte_min" = "MP-MOL vs MP-TE (min)",
"MPmol_MPte_mean" = "MP-MOL vs MP-TE (mean)",
"MLmol_MLteAsc" = "ML-MOL vs ML-TE (with ASC)",
"MLmol_MLteNoAsc" = "ML-MOL vs ML-TE (without ASC)"
)
s1_rf = ggplot(df_extinct, aes(x=RFdist, y=comparison, fill=comparison))+
geom_density_ridges() +
scale_x_continuous(limits = c(0, 1)) +  # Set lower limit to 0, prevents extrapolation below 0
theme_ridges()+
labs(x="Normalized RF", y=NULL,tag="A")+
scale_fill_manual(values = custom_palette, labels = custom_labels)+
geom_vline(xintercept = 0, color = "black", linetype = "dashed", linewidth = 1, alpha=.5) +
theme(
axis.text.y = element_blank(),  # Remove y-axis values
legend.position = "none",     # Move the legend below the plot
legend.direction = "horizontal", # Display legend items horizontally (side by side)
legend.box = "horizontal",      # Make sure the legend is laid out horizontally
legend.title = element_blank(),  # Optional: Remove legend title
legend.text = element_text(size = 8),  # Reduce the size of legend text
legend.key.size = unit(0.5, "cm"),    # Reduce the size of legend keys
axis.title.x = element_text(hjust = 0.5)  # Center the x-axis title
)
s1_cid = ggplot(df_extinct, aes(x=CID, y=comparison, fill=comparison))+
geom_density_ridges() +
scale_x_continuous(limits = c(0, 1)) +  # Set lower limit to 0, prevents extrapolation below 0
theme_ridges()+
labs(x="Normalized CID", y=NULL,tag="B")+
scale_fill_manual(values = custom_palette, labels = custom_labels)+
geom_vline(xintercept = 0, color = "black", linetype = "dashed", size = 1, alpha=.5) +
theme(
axis.text.y = element_blank(),  # Remove y-axis values
legend.position = "none",     # Move the legend below the plot
legend.direction = "horizontal", # Display legend items horizontally (side by side)
legend.box = "horizontal",      # Make sure the legend is laid out horizontally
legend.title = element_blank(),  # Optional: Remove legend title
legend.text = element_text(size = 8),  # Reduce the size of legend text
legend.key.size = unit(0.5, "cm"),    # Reduce the size of legend keys
axis.title.x = element_text(hjust = 0.5)  # Center the x-axis title
)
s1_spr = ggplot(df_extinct, aes(x=SPR, y=comparison, fill=comparison))+
geom_density_ridges() +
scale_x_continuous(limits = c(0, 1)) +  # Set lower limit to 0, prevents extrapolation below 0
theme_ridges()+
labs(x="Normalized SPR", y=NULL,tag="C")+
scale_fill_manual(values = custom_palette, labels = custom_labels)+
geom_vline(xintercept = 0, color = "black", linetype = "dashed", size = 1, alpha=.5) +
theme(
axis.text.y = element_blank(),  # Remove y-axis values
legend.position = "none",     # Move the legend below the plot
legend.direction = "horizontal", # Display legend items horizontally (side by side)
legend.box = "horizontal",      # Make sure the legend is laid out horizontally
legend.title = element_blank(),  # Optional: Remove legend title
legend.text = element_text(size = 8),  # Reduce the size of legend text
legend.key.size = unit(0.5, "cm"),    # Reduce the size of legend keys
axis.title.x = element_text(hjust = 0.5)  # Center the x-axis title
)
# Extract the legend as a separate ggplot object
legend <- ggplot(df_extinct, aes(x = comparison, y = CID, color = comparison)) +
geom_point() +
scale_color_manual(values = custom_palette, labels = custom_labels) +
theme_minimal() +
theme(
legend.position = "bottom",
legend.title = element_blank(),
panel.grid = element_blank(),
panel.background = element_blank(),
axis.title = element_blank(),
axis.text = element_blank(),
axis.ticks = element_blank(),
legend.box.margin = margin(t = 15, b=15)   # space above legend
)+
guides(color = guide_legend(nrow=2, byrow=T, override.aes = list(size = 2, alpha=.7)))  # Increase dot size in legend
legend_grob <- cowplot::get_legend(legend)
tiff("Figures/figS2_density.tiff", width = 6, height = 10, units = "in", res = 300)
grid.arrange(arrangeGrob(s1_rf + theme(plot.margin = margin(.01,1,1,.01)),
s1_cid + theme(plot.margin = margin(.01,1,1,.01)),
s1_spr + theme(plot.margin = margin(.01,1,1,.01)),
nrow=3, ncol=1),
legend_grob,
nrow=2,
heights= c(20,1))
dev.off()
