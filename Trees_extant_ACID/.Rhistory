cat("Tips present in Tree 1 but missing in Tree 2:\n", missing_in_tree2, "\n")
}
}
if (setequal(tips_tree1, tips_tree2)) {
cat("The two trees have the same tips.\n")
} else {
# Identify missing tips in each tree
missing_in_tree1 <- setdiff(tips_tree2, tips_tree1)
missing_in_tree2 <- setdiff(tips_tree1, tips_tree2)
# Display the missing tips
if (length(missing_in_tree1) > 0) {
cat("Tips present in Tree 2 but missing in Tree 1:\n", missing_in_tree1, "\n")
}
if (length(missing_in_tree2) > 0) {
cat("Tips present in Tree 1 but missing in Tree 2:\n", missing_in_tree2, "\n")
}
}
# Extract the tip labels from both trees
tips_tree1 <- length$tip.label
tips_tree2 <- consensus$tip.label
# Check if the tips are the same
if (setequal(tips_tree1, tips_tree2)) {
cat("The two trees have the same tips.\n")
} else {
# Identify missing tips in each tree
missing_in_tree1 <- setdiff(tips_tree2, tips_tree1)
missing_in_tree2 <- setdiff(tips_tree1, tips_tree2)
# Display the missing tips
if (length(missing_in_tree1) > 0) {
cat("Tips present in Tree 2 but missing in Tree 1:\n", missing_in_tree1, "\n")
}
if (length(missing_in_tree2) > 0) {
cat("Tips present in Tree 1 but missing in Tree 2:\n", missing_in_tree2, "\n")
}
}
