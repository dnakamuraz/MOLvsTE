# Load data
df <- read.csv("Dataset_R_q123_08-25.csv")
#df_extinct <- df %>% filter(grepl("Extinct", Type)) # keep only extinct datasets
# Keep only extinct
extinct_datasets <- unique(df$Dataset[df$Type == "Extinct"])
# Append the extant datasets that do not appear among extinct
df_extinct <- df[df$Type == "Extinct" |
(df$Type == "Extant" & !(df$Dataset %in% extinct_datasets)), ]
# Grid 3x3
panel_grid <- arrangeGrob(
plot_mlasc_rf_fossil,
plot_mlno_rf_fossil,
plot_mp_rf_min_fossil,
plot_mp_rf_strict_fossil,
plot_mlasc_cid_fossil,
plot_mlno_cid_fossil,
plot_mp_cid_min_fossil,
plot_mp_cid_strict_fossil,
plot_mlasc_spr_fossil,
plot_mlno_spr_fossil,
plot_mp_spr_min_fossil,
legend_grob,
nrow = 3, ncol = 4
)
# Write
tiff("Figures/figS3_proportion_fossils.tiff", width = 16, height = 10, units = "in", res = 300)
grid.arrange(
arrangeGrob(
panel_grid,
padding = unit(c(0.8,0.2,0.2,1.5), "cm")  # top right bottom left
),
nrow = 2,
heights = c(20,1)
)
dev.off()
# Extract the legend as a separate ggplot object
legend_df <- data.frame(
comparison = factor(
c("MPmol_MPte_min","MPmol_MPte_strict","MLmol_MLteAsc","MLmol_MLteNoAsc"),
levels = c("MPmol_MPte_min","MPmol_MPte_strict","MLmol_MLteAsc","MLmol_MLteNoAsc")
),
value = 1
)
legend <- ggplot(legend_df, aes(x = comparison, y = value, color = comparison)) +
geom_point() +
scale_color_manual(values = custom_palette, labels = custom_labels) +
theme_minimal() +
theme(
legend.position = "bottom",
legend.title = element_blank(),
panel.grid = element_blank(),
panel.background = element_blank(),
axis.title = element_blank(),
axis.text = element_blank(),
axis.ticks = element_blank(),
legend.box.margin = margin(t = 15, b = 15)
) +
guides(color = guide_legend(nrow = 4, byrow = TRUE,
override.aes = list(size = 2, alpha = .7)))
legend_grob <- cowplot::get_legend(legend)
