#stat_cor(method = "spearman", label.x = 0.08, label.y = 0.6) +  # add Spearman correlation value
theme_minimal()+
labs(y = "Normalized RF\n", x = NULL)
print("Minimum CID: MP MOL vs MP TE")
cor.test(df_extinct$X.Morph.Total, df_extinct$MP_MOLvsTE_NormalizedMinCID, method = "spearman")
plot_mp_cid_min_fossil = ggplot(df_extinct, aes(x = X.Morph.Total, y = MP_MOLvsTE_NormalizedMinCID)) +
