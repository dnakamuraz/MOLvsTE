sd_value = sd(value, na.rm = TRUE),
min_value = min(value, na.rm=T),
max_value = max(value, na.rm=T),
n = n())
print("RF")
shapiro.test(q3_rf$value) # p < 0.05, non-parametric
print("Kruskal-Wallis: non-parametric test for multiple groups (non-paired values)")
kruskal.test(q3_rf$value ~ q3_rf$source)
print("Friedman: non-parametric test for paired values and multiple groups")
q3_rf_fri = data.frame(df_extant$MP_MOLvsTE_NormalizedMinRF, df_extant$MP_MOLvsTE_NormalizedMeanRF, df_extant$MP_MOLvsTE_NormalizedRF_strictConsensus, df_extant$ML_MOLvsTEASC_NormalizedRF, df_extant$ML_MOLvsTEnoASC_NormalizedRF)
friedman.test(as.matrix(q3_rf_fri))
print("Wilcoxon: pairwise comparisons for paired values")
pairwise.wilcox.test(x=unlist(q3_rf_fri),
g=factor(base::rep(names(q3_rf_fri), each = nrow(q3_rf_fri))),
paired=TRUE,
p.adjust.method="bonferroni")
print("CID")
shapiro.test(q3_cid$value) # p < 0.05, non-parametric
print("Kruskal-Wallis: non-parametric test for multiple groups")
kruskal.test(q3_cid$value ~ q3_cid$source)
print("Friedman: non-parametric test for paired values and multiple groups")
q3_cid_fri = data.frame(df_extant$MP_MOLvsTE_NormalizedMinCID, df_extant$MP_MOLvsTE_NormalizedMeanCID, df_extant$MP_MOLvsTE_NormalizedCID_strictConsensus, df_extant$ML_MOLvsTEASC_NormalizedCID, df_extant$ML_MOLvsTEnoASC_NormalizedCID)
friedman.test(as.matrix(q3_cid_fri))
print("Wilcoxon: pairwise comparisons for paired values")
pairwise.wilcox.test(x=unlist(q3_cid_fri),
g=factor(base::rep(names(q3_cid_fri), each = nrow(q3_cid_fri))),
paired=TRUE,
p.adjust.method="bonferroni")
print("SPR")
shapiro.test(q3_spr$value) # p < 0.05, non-parametric
print("Kruskal-Wallis: non-parametric test for multiple groups")
kruskal.test(q3_spr$value ~ q3_spr$source)
print("Friedman: non-parametric test for paired values and multiple groups")
q3_spr_fri = data.frame(df_extant$MP_MOLvsTE_NormalizedMinSPR,df_extant$MP_MOLvsTE_NormalizedMeanSPR, df_extant$ML_MOLvsTEASC_NormalizedSPR, df_extant$ML_MOLvsTEnoASC_NormalizedSPR)
friedman.test(as.matrix(q3_spr_fri))
print("Wilcoxon: pairwise comparisons for paired values")
pairwise.wilcox.test(x=unlist(q3_spr_fri),
g=factor(base::rep(names(q3_spr_fri), each = nrow(q3_spr_fri))),
paired=TRUE,
p.adjust.method="bonferroni")
# Load data
df <- read.csv("Dataset_R_q123_08-25.csv")
#df_extinct <- df %>% filter(grepl("Extinct", Type)) # keep only extinct datasets
# Keep only extinct
extinct_datasets <- unique(df$Dataset[df$Type == "Extinct"])
# Append the extant datasets that do not appear among extinct
df_extinct <- df[df$Type == "Extinct" |
(df$Type == "Extant" & !(df$Dataset %in% extinct_datasets)), ]
# Create an empty data frame for RF
q3_rf_extinct <- data.frame(value = numeric(0), source = character(0))
# Combine the vectors of RF into the data frame
q3_rf_extinct <- rbind(q3_rf_extinct, data.frame(value = df_extinct$MP_MOLvsTE_NormalizedMinRF, source = base::rep("MP_MOLvsTE_min", length(df_extinct$MP_MOLvsTE_NormalizedMinRF))))
q3_rf_extinct <- rbind(q3_rf_extinct, data.frame(value = df_extinct$MP_MOLvsTE_NormalizedMeanRF, source = base::rep("MP_MOLvsTE_mean", length(df_extinct$MP_MOLvsTE_NormalizedMeanRF))))
q3_rf_extinct <- rbind(q3_rf_extinct, data.frame(value = df_extinct$MP_MOLvsTE_NormalizedRF_strictConsensus, source = base::rep("MP_MOLvsTE_strict", length(df_extinct$MP_MOLvsTE_NormalizedRF_strictConsensus))))
q3_rf_extinct <- rbind(q3_rf_extinct, data.frame(value = df_extinct$ML_MOLvsTEASC_NormalizedRF, source = base::rep("ML_MOLvsTEASC", length(df_extinct$ML_MOLvsTEASC_NormalizedRF))))
q3_rf_extinct <- rbind(q3_rf_extinct, data.frame(value = df_extinct$ML_MOLvsTEnoASC_NormalizedRF, source = base::rep("ML_MOLvsTEnoASC", length(df_extinct$ML_MOLvsTEnoASC_NormalizedRF))))
# Summary of medians
q3_rf_extinct %>%
group_by(source) %>%
summarise(
median_value = median(value, na.rm = TRUE),
sd_value = sd(value, na.rm = TRUE),
min_value = min(value, na.rm=T),
max_value = max(value, na.rm=T),
n = n())
