# Set order of comparisons
q3_rf$source <- factor(q3_rf$source, levels = c("MP_MOLvsTE_min", "MP_MOLvsTE_mean", "MP_MOLvsTE_strict", "ML_MOLvsTEASC", "ML_MOLvsTEnoASC"))
q3_cid$source <- factor(q3_cid$source, levels = c("MP_MOLvsTE_min", "MP_MOLvsTE_mean", "MP_MOLvsTE_strict","ML_MOLvsTEASC", "ML_MOLvsTEnoASC"))
# Set colors
custom_palette <- c("MP_MOLvsTE_min" = "#339999", "MP_MOLvsTE_mean"="#335100", "MP_MOLvsTE_strict"="#331100", "ML_MOLvsTEASC" = "#6f77b4", "ML_MOLvsTEnoASC" = "#cccccc")
# Create custom legend labels
custom_labels <- c(
"MP_MOLvsTE_min" = "MP-MOL vs MP-TE (min)",
"MP_MOLvsTE_mean" = "MP-MOL vs MP-TE (mean)",
"MP_MOLvsTE_strict"= "MP-MOL vs MP-TE (strict consensus)",
"ML_MOLvsTEASC" = "ML-MOL vs ML-TE MKv",
"ML_MOLvsTEnoASC" = "ML-MOL vs ML-TE MK"
)
# Boxplot Normalized RF
plot_q3_rf = ggplot(q3_rf, aes(x = source, y = value)) +
geom_boxplot(outlier.shape = NA) +  # Create boxplot without default outliers
geom_jitter(aes(color = source), alpha = .4, width = 0.2) +  # Add transparent dots
labs(x = "", y = "Normalized RF\n", tag="A") +
theme_minimal() +
theme(axis.title.x = element_blank(),axis.text.x = element_blank(), axis.ticks.x = element_blank(), legend.position = "none") +  # Hide legend if not needed
scale_color_manual(values = custom_palette, labels = custom_labels)
# Boxplot CID
plot_q3_cid = ggplot(q3_cid, aes(x = source, y = value)) +
geom_boxplot(outlier.shape = NA) +  # Create boxplot without default outliers
geom_jitter(aes(color = source), alpha = .4, width = 0.2) +  # Add transparent dots
labs(x = "", y = "\nNormalized CID\n", tag="B") +
theme_minimal() +
theme(axis.title.x = element_blank(),axis.text.x = element_blank(),axis.ticks.x = element_blank(),legend.position = "none") +  # Hide legend if not needed
scale_color_manual(values = custom_palette, labels = custom_labels)
q3_rf_extinct$source <- factor(q3_rf_extinct$source, levels = c("MP_MOLvsTE_min", "MP_MOLvsTE_mean","MP_MOLvsTE_strict", "ML_MOLvsTEASC", "ML_MOLvsTEnoASC"))
q3_cid_extinct$source <- factor(q3_cid_extinct$source, levels = c("MP_MOLvsTE_min", "MP_MOLvsTE_mean","MP_MOLvsTE_strict", "ML_MOLvsTEASC", "ML_MOLvsTEnoASC"))
# Boxplot Normalized RF
plot_q3_rf_extinct = ggplot(q3_rf_extinct, aes(x = source, y = value)) +
geom_boxplot(outlier.shape = NA) +  # Create boxplot without default outliers
geom_jitter(aes(color = source), alpha = .4, width = 0.2) +  # Add transparent dots
labs(x = "", y = "", tag="C") +
theme_minimal() +
theme(axis.title.x = element_blank(),axis.text.x = element_blank(), axis.ticks.x = element_blank(),legend.position = "none") +  # Hide legend if not needed
scale_color_manual(values = custom_palette, labels = custom_labels)
# Boxplot CID
plot_q3_cid_extinct = ggplot(q3_cid_extinct, aes(x = source, y = value)) +
geom_boxplot(outlier.shape = NA) +  # Create boxplot without default outliers
geom_jitter(aes(color = source), alpha = .4, width = 0.2) +  # Add transparent dots
labs(x = "", y = "", tag="D") +
theme_minimal() +
theme(axis.title.x = element_blank(),axis.text.x = element_blank(),axis.ticks.x = element_blank(),legend.position = "none") +  # Hide legend if not needed
scale_color_manual(values = custom_palette, labels = custom_labels)
legend <- cowplot::get_legend(
plot_q3_rf +
theme(legend.position = "bottom")
)
plots = grid.arrange(plot_q3_rf + theme(plot.margin = margin(.01,1,1,.01)),
plot_q3_rf_extinct + theme(plot.margin = margin(.01,1,1,.01)),
plot_q3_cid + theme(plot.margin = margin(.001,1,1,.01)),
plot_q3_cid_extinct + theme(plot.margin = margin(.001,1,1,.01)),
nrow=2, ncol=2)
# Plot 2x1
tiff("Figures/fig4_boxplots_strictConsensus.tiff", width = 7, height = 6, units = "in", res = 300)
plots
cowplot::plot_grid(
plots,
legend,
ncol = 1,
rel_heights = c(1, 0.12)
)
dev.off()
tiff("Figures/fig4_boxplots_strictConsensus.tiff", width = 7, height = 6, units = "in", res = 300)
plots
cowplot::plot_grid(
plots,
legend,
ncol = 2,
rel_heights = c(1, 0.12)
)
dev.off()
