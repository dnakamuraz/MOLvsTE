# Load data
df <- read.csv("Dataset_R_q123_08-25.csv")
#df_extinct <- df %>% filter(grepl("Extinct", Type)) # keep only extinct datasets
# Keep only extinct
extinct_datasets <- unique(df$Dataset[df$Type == "Extinct"])
# Append the extant datasets that do not appear among extinct
df_extinct <- df[df$Type == "Extinct" |
(df$Type == "Extant" & !(df$Dataset %in% extinct_datasets)), ]
print("Minimum RF: MP MOL vs MP TE")
cor.test(df_extinct$X.Morph.Total, df_extinct$MP_MOLvsTE_NormalizedMinRF, method = "spearman")
plot_mp_rf_min_fossil = ggplot(df_extinct, aes(x = X.Morph.Total, y = MP_MOLvsTE_NormalizedMinRF)) +
geom_point() +  # scatter plot
geom_smooth(method = "lm", formula = y ~ x, color = "#339999", se = FALSE) +  # regression line (lm) for the trend
#stat_cor(method = "spearman", label.x = 0.08, label.y = 0.6) +  # add Spearman correlation value
theme_minimal()+
labs(y = "Normalized RF\n", x = NULL)
print("Strict RF: MP MOL vs MP TE")
cor.test(df_extinct$X.Morph.Total, df_extinct$MP_MOLvsTE_NormalizedRF_strictConsensus, method = "spearman")
plot_mp_rf_strict_fossil = ggplot(df_extinct, aes(x = X.Morph.Total, y = MP_MOLvsTE_NormalizedRF_strictConsensus)) +
geom_point() +  # scatter plot
