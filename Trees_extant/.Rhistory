library(ape)
tips1 <- ml_mol_best[[7]]$tip.label
tips2 <- ml_te_noasc_best[[7]]$tip.label
unique_in_1 <- setdiff(tips1, tips2)
unique_in_2 <- setdiff(tips2, tips1)
if (length(unique_in_1) == 0 && length(unique_in_2) == 0) {
message("Both trees share the exact same set of leaves.")
} else {
if (length(unique_in_1) > 0) {
cat("Leaves unique to ml_mol_best[[7]]:\n")
print(unique_in_1)
}
if (length(unique_in_2) > 0) {
cat("Leaves unique to ml_te_noasc_best[[7]]:\n")
print(unique_in_2)
}
}
